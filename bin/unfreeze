#!/bin/bash

firefox () {
	/usr/bin/killall -SIGCONT firefox
    echo "UnFroze Firefox"
}

vlc () {
        /usr/bin/killall -SIGCONT VLC
	    echo "UnFroze VLC"
}

safari () {
        /usr/bin/killall -SIGCONT Safari
           echo "UnFroze Safari"
}


### main logic ###
case "$1" in
  firefox)
        firefox
	;;
  vlc)
	vlc
	;;
  safari)
        safari
	;;

  status)
	status FOO
	;;
	firefox|vlc)
stop
start
;;
*)
echo $"Usage: $0 {firefox|vlc|safari}"
exit 1
esac

exit 0
