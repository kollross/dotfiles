#!/bin/sh
tmux new-session -d -s kollross
 
#### Win 0 ####

# Win 0
tmux set-window-option -t $SESSION -g automatic-rename off
tmux new-window    -t $SESSION:0 -k -n '[shredder]' 'ssh -4 shredder'
tmux set-window-option -t $SESSION:0 automatic-rename off

 
tmux new-window -t kollross:1 -n '[Shaolin]' 
tmux new-window -t kollross:2 -n '[Merlin]' 'ssh -4  merlin'
tmux new-window -t kollross:2 -n '[OmniOS]' 'ssh -4  omnios'
tmux new-window -t kollross:2 -n '[TrueNAS]' 'ssh -4  truenas'
tmux select-window -t kollross:1
tmux -2 attach-session -t kollross
